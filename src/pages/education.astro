---
import { Award, GraduationCap } from "@lucide/astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import { certifications, education, profile } from "../data/profile";
import { assetPath } from "../utils/paths";

const title = `Education | ${profile.name}`;
const description = `Education and certifications for ${profile.name}.`;
---

<BaseLayout title={title} description={description}>
  <Header />
  <main>
    <section class="relative border-b border-white/10 py-20 sm:py-24">
      <div class="absolute inset-0 bg-gradient-to-b from-blue-600/10 via-transparent to-violet-600/10"></div>
      <div class="relative mx-auto max-w-6xl px-5 text-center sm:px-6 lg:px-8">
        <a class="text-sm font-semibold text-blue-300 underline decoration-blue-400/40 underline-offset-4 hover:text-white" href={assetPath("")}>
          Back to home
        </a>
        <p class="mt-8 text-sm font-semibold uppercase tracking-[0.16em] text-blue-300">Education</p>
        <h1 class="mt-3 text-5xl font-bold text-white sm:text-6xl">Education and Certifications</h1>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-slate-400">
          Academic background, certifications, and technical activities that support my work as a computer engineer.
        </p>
      </div>
    </section>

    <section class="py-12 sm:py-14">
      <div class="mx-auto grid max-w-6xl gap-10 px-5 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:px-8">
        <div>
          <div class="mb-6 flex items-center gap-3">
            <GraduationCap class="h-6 w-6 text-blue-300" aria-hidden="true" stroke-width={2} />
            <h2 class="text-2xl font-bold text-white">Education</h2>
          </div>
          <div class="grid gap-4">
            {education.map((item) => (
              <article class="glass-card rounded-2xl p-6">
                <p class="text-sm font-semibold uppercase tracking-[0.16em] text-blue-300">{item.period}</p>
                <h3 class="mt-3 text-2xl font-bold text-white">{item.degree}</h3>
                <p class="mt-2 text-base font-medium text-slate-200">{item.institution}</p>
                <p class="mt-1 text-sm text-slate-500">{item.location}</p>
                <p class="mt-4 text-sm leading-6 text-slate-400">{item.description}</p>
              </article>
            ))}
          </div>
        </div>

        <div>
          <div class="mb-6 flex items-center gap-3">
            <Award class="h-6 w-6 text-blue-300" aria-hidden="true" stroke-width={2} />
            <h2 class="text-2xl font-bold text-white">Certifications and Activities</h2>
          </div>
          <div class="grid gap-4">
            {certifications.map((item) => (
              <article class="glass-card rounded-2xl p-6">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                  <div>
                    <h3 class="text-xl font-bold text-white">{item.title}</h3>
                    <p class="mt-1 text-sm font-medium text-blue-300">{item.issuer}</p>
                  </div>
                  <p class="text-sm font-semibold text-slate-500">{item.year}</p>
                </div>
                <p class="mt-4 text-sm leading-6 text-slate-400">{item.description}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
  <footer class="border-t border-white/10 bg-blue-600/5 py-8">
    <div class="mx-auto flex max-w-6xl flex-col gap-2 px-5 text-sm text-slate-500 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
      <p>{profile.name}</p>
      <p>{profile.location}</p>
    </div>
  </footer>
</BaseLayout>
