---
import { Award, BriefcaseBusiness, CalendarDays, ChevronDown, ExternalLink, GraduationCap, MapPin } from "@lucide/astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import { certifications, education, experience, profile } from "../data/profile";
import { getTechLogo } from "../utils/techLogos";
import { assetPath } from "../utils/paths";

const title = `Journey | ${profile.name}`;
const description = `Education, certifications, and experience for ${profile.name}.`;

const journeyTabs = [
  { id: "education", label: "Education", Icon: GraduationCap },
  { id: "certifications", label: "Certifications", Icon: Award },
  { id: "experience", label: "Experience", Icon: BriefcaseBusiness },
];

const certificationGroups = [
  "Competition & Award Certifications",
  "Course Certifications",
  "Professional & Vendor Certifications",
].map((category) => ({
  category,
  items: certifications.filter((item) => item.category === category),
}));
---

<BaseLayout title={title} description={description}>
  <div class="flex min-h-screen flex-col">
    <Header />
  <main class="grow">
    <section class="py-8 sm:py-10" data-journey-tabs>
      <div class="mx-auto max-w-6xl px-5 sm:px-6 lg:px-8">
        <div class="glass-card mb-8 flex flex-col gap-3 rounded-2xl p-3 sm:flex-row" role="tablist" aria-label="Journey categories">
          {
            journeyTabs.map(({ id, label, Icon }, index) => (
              <button
                class:list={[
                  "inline-flex min-h-12 flex-1 items-center justify-center gap-2 rounded-xl px-4 py-3 text-sm font-semibold transition",
                  index === 0 ? "bg-blue-500/25 text-white ring-1 ring-blue-400/50" : "text-slate-400 hover:bg-white/10 hover:text-white",
                ]}
                type="button"
                id={`journey-tab-${id}`}
                role="tab"
                aria-selected={index === 0 ? "true" : "false"}
                aria-controls={`journey-panel-${id}`}
                data-journey-tab={id}
              >
                <Icon class="h-4 w-4" aria-hidden="true" stroke-width={2} />
                {label}
              </button>
            ))
          }
        </div>

        <section id="journey-panel-education" role="tabpanel" aria-labelledby="journey-tab-education" data-journey-panel="education">
          <div class="relative grid gap-5 before:hidden before:absolute before:left-6 before:top-2 before:h-full before:w-px before:bg-blue-500/30 md:before:block">
            {
              education.map((item) => (
                <article class="glass-card relative rounded-2xl p-6 md:ml-14">
                  <span class="absolute -left-14 top-7 hidden h-12 w-12 items-center justify-center rounded-2xl border border-blue-400/30 bg-[#0a0e27] text-blue-300 md:flex">
                    <GraduationCap class="h-6 w-6" aria-hidden="true" stroke-width={2} />
                  </span>
                  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                    <div>
                      <p class="inline-flex items-center gap-2 text-sm font-semibold text-blue-300">
                        <CalendarDays class="h-4 w-4" aria-hidden="true" stroke-width={2} />
                        {item.year}
                      </p>
                      <h2 class="mt-3 text-2xl font-bold text-white">{item.degree}</h2>
                      <p class="mt-2 text-lg font-semibold text-slate-200">{item.institution}</p>
                      {"result" in item && item.result && <p class="mt-2 text-sm font-semibold text-blue-300">{item.result}</p>}
                      <p class="mt-1 inline-flex items-center gap-2 text-sm text-slate-500">
                        <MapPin class="h-4 w-4" aria-hidden="true" stroke-width={2} />
                        {item.location}
                      </p>
                    </div>
                  </div>
                  <p class="mt-5 text-sm leading-6 text-slate-400">{item.description}</p>
                  <div class="mt-5">
                    <h3 class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-300">Relevant Coursework</h3>
                    <div class="mt-3 flex flex-wrap gap-2">
                      {item.coursework.map((course) => <span class="rounded-full border border-white/15 bg-white/10 px-3 py-1 text-xs font-semibold text-slate-200">{course}</span>)}
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </section>

        <section id="journey-panel-certifications" class="hidden" role="tabpanel" aria-labelledby="journey-tab-certifications" data-journey-panel="certifications">
          <div class="grid gap-4">
            {
              certificationGroups.map((group, index) => (
                <details class="glass-card group rounded-2xl p-0" open={index === 0}>
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 rounded-2xl px-5 py-4 text-white transition hover:bg-white/5">
                    <span class="inline-flex items-center gap-3">
                      <span class="flex h-10 w-10 items-center justify-center rounded-xl border border-blue-400/30 bg-blue-500/15 text-blue-300">
                        <Award class="h-5 w-5" aria-hidden="true" stroke-width={2} />
                      </span>
                      <span class="font-bold">{group.category}</span>
                    </span>
                    <ChevronDown class="h-5 w-5 flex-none text-blue-300 transition group-open:rotate-180" aria-hidden="true" stroke-width={2} />
                  </summary>

                  <div class="border-t border-white/10 px-5">
                    {
                      group.items.length > 0 ? (
                        <ul class="divide-y divide-white/10">
                          {group.items.map((item) => (
                            <li class="flex flex-col gap-4 py-4 lg:flex-row lg:items-center lg:justify-between">
                              <div>
                                <div class="flex flex-wrap items-center gap-3">
                                  <h2 class="text-lg font-bold text-white">{item.title}</h2>
                                  <span class="rounded-full border border-white/15 bg-white/10 px-3 py-1 text-xs font-semibold text-slate-300">{item.year}</span>
                                </div>
                                <p class="mt-1 text-sm font-semibold text-blue-300">{item.issuer}</p>
                                <p class="mt-2 text-sm leading-6 text-slate-400">{item.description}</p>
                              </div>
                              {
                                item.credentialHref ? (
                                  <a
                                    href={assetPath(item.credentialHref)}
                                    target="_blank"
                                    rel="noreferrer"
                                    class="inline-flex min-h-10 flex-none items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-blue-600 to-violet-600 px-4 py-2 text-sm font-semibold text-white transition hover:from-blue-700 hover:to-violet-700"
                                  >
                                    View Credential
                                    <ExternalLink class="h-4 w-4" aria-hidden="true" stroke-width={2} />
                                  </a>
                                ) : null
                              }
                            </li>
                          ))}
                        </ul>
                      ) : (
                        <p class="py-5 text-sm leading-6 text-slate-400">
                          No certifications added yet.
                        </p>
                      )
                    }
                  </div>
                </details>
              ))
            }
          </div>
        </section>

        <section id="journey-panel-experience" class="hidden" role="tabpanel" aria-labelledby="journey-tab-experience" data-journey-panel="experience">
          <div class="grid gap-5">
            {
              experience.map((item) => (
                <article class="glass-card rounded-2xl p-6">
                  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                    <div>
                      <p class="inline-flex items-center gap-2 text-sm font-semibold text-blue-300">
                        <CalendarDays class="h-4 w-4" aria-hidden="true" stroke-width={2} />
                        {item.period}
                      </p>
                      <h2 class="mt-3 text-2xl font-bold text-white">{item.role}</h2>
                      <p class="mt-2 text-lg font-semibold text-slate-200">{item.company}</p>
                      <p class="mt-1 text-sm text-slate-500">{item.department}</p>
                    </div>
                    <div class="rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-sm text-slate-300 lg:text-right">
                      <p class="font-semibold text-white">{item.duration}</p>
                      <p class="mt-1">{item.project}</p>
                    </div>
                  </div>

                  <p class="mt-5 text-base leading-7 text-slate-400">{item.summary}</p>
                  <ul class="mt-5 grid gap-2 text-sm leading-6 text-slate-300">
                    {item.highlights.map((highlight) => <li class="border-l-2 border-blue-500 pl-3">{highlight}</li>)}
                  </ul>
                  <div class="mt-6">
                    <h3 class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-300">Technologies Used</h3>
                    <div class="mt-3 flex flex-wrap gap-2">
                      {
                        item.stack.map((tool) => (
                          <span class="inline-flex items-center gap-2 rounded-full border border-blue-500/30 bg-blue-500/20 px-3 py-1 text-xs font-semibold text-blue-100">
                            <span class="image-load-frame flex h-6 w-6 items-center justify-center rounded-full bg-white p-1" data-image-frame>
                              <img src={getTechLogo(tool)} alt={`${tool} logo`} class="h-full w-full object-contain" loading="lazy" data-load-image />
                            </span>
                            {tool}
                          </span>
                        ))
                      }
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </section>
      </div>
    </section>
  </main>
  <footer class="border-t border-white/10 bg-blue-600/5 py-8">
    <div class="mx-auto flex max-w-6xl flex-col gap-2 px-5 text-sm text-slate-500 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
      <p>{profile.name}</p>
      <p>{profile.location}</p>
    </div>
  </footer>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll("[data-journey-tabs]").forEach((root) => {
    const tabs = Array.from(root.querySelectorAll("[data-journey-tab]"));
    const panels = Array.from(root.querySelectorAll("[data-journey-panel]"));

    function selectTab(id) {
      tabs.forEach((tab) => {
        if (!(tab instanceof HTMLButtonElement)) {
          return;
        }

        const isSelected = tab.dataset.journeyTab === id;
        tab.setAttribute("aria-selected", String(isSelected));
        tab.classList.toggle("bg-blue-500/25", isSelected);
        tab.classList.toggle("text-white", isSelected);
        tab.classList.toggle("ring-1", isSelected);
        tab.classList.toggle("ring-blue-400/50", isSelected);
        tab.classList.toggle("text-slate-400", !isSelected);
      });

      panels.forEach((panel) => {
        if (!(panel instanceof HTMLElement)) {
          return;
        }

        const isSelected = panel.dataset.journeyPanel === id;
        panel.classList.toggle("hidden", !isSelected);
      });
    }

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        if (tab instanceof HTMLButtonElement) {
          selectTab(tab.dataset.journeyTab ?? "education");
        }
      });
    });
  });
</script>
