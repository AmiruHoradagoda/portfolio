---
import { Download, Mail } from "@lucide/astro";
import { profile } from "../data/profile";
import { assetPath } from "../utils/paths";

const cvUrl = assetPath(profile.cvPath);
const imageUrl = assetPath(profile.imagePath);
---

<section class="relative overflow-hidden px-5 py-20 text-white sm:px-6 lg:px-8">
  <div class="absolute inset-0 bg-gradient-to-b from-blue-600/10 via-transparent to-violet-600/10"></div>
  <div class="mx-auto grid min-h-[calc(100vh-4rem)] max-w-5xl items-center gap-12 lg:grid-cols-[1fr_0.85fr]">
    <div class="relative z-10 max-w-xl">
      <h1 class="text-5xl font-extrabold leading-[1.05] text-white sm:text-6xl">
        Hi, I'm {profile.name}
      </h1>
      <p class="mt-7 text-2xl font-normal leading-snug text-slate-300">
        Computer Engineering Undergraduate | Full Stack Developer
      </p>
      <p class="mt-7 max-w-lg text-lg leading-8 text-slate-400">
        I build accessible, user-friendly websites and applications with modern technologies, reliable backend systems, DevOps workflows, and applied AI.
      </p>

      <div class="mt-9 flex flex-col gap-4 sm:flex-row">
        <a
          href={assetPath("#contact")}
          class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md bg-gradient-to-r from-blue-600 to-violet-600 px-5 py-3 text-base font-semibold text-white transition hover:from-blue-700 hover:to-violet-700 focus:outline-none focus:ring-4 focus:ring-blue-500/20"
        >
          <Mail class="h-5 w-5" aria-hidden="true" stroke-width={2} />
          Get in touch
        </a>
        <a
          href={cvUrl}
          download
          class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md border border-white/20 bg-white/10 px-5 py-3 text-base font-semibold text-white transition hover:bg-white/20 focus:outline-none focus:ring-4 focus:ring-white/10"
        >
          <Download class="h-5 w-5" aria-hidden="true" stroke-width={2} />
          Download Resume (PDF)
        </a>
      </div>
    </div>

    <div class="relative z-10 flex justify-center lg:justify-end">
      <div class="image-load-frame h-72 w-72 overflow-hidden rounded-full border-4 border-white/20 bg-[#071527] shadow-2xl shadow-blue-950/40 sm:h-80 sm:w-80 lg:h-96 lg:w-96" data-image-frame>
        <img
          src={imageUrl}
          alt="Professional portrait of Amiru Horadagoda"
          class="h-full w-full object-cover object-[center_18%]"
          loading="eager"
          data-load-image
        />
      </div>
    </div>
  </div>
</section>
