---
interface Props {
  item: {
    company: string;
    department: string;
    role: string;
    period: string;
    duration: string;
    project: string;
    summary: string;
    highlights: string[];
    stack: string[];
  };
}

const { item } = Astro.props;
---

<article class="glass-card rounded-2xl p-6">
  <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-blue-300">{item.period}</p>
      <h3 class="mt-3 text-2xl font-bold text-white">{item.role}</h3>
      <p class="mt-2 text-lg text-slate-200">{item.company}</p>
      <p class="mt-1 text-sm text-slate-500">{item.department}</p>
    </div>
    <div class="text-sm text-slate-500 md:text-right">
      <p>{item.duration}</p>
      <p>{item.project}</p>
    </div>
  </div>

  <p class="mt-5 max-w-3xl text-base leading-7 text-slate-400">{item.summary}</p>
  <ul class="mt-5 grid gap-2 text-sm leading-6 text-slate-300">
    {item.highlights.map((highlight) => <li class="border-l-2 border-blue-500 pl-3">{highlight}</li>)}
  </ul>
  <div class="mt-5 flex flex-wrap gap-2">
    {item.stack.map((tool) => <span class="rounded-full border border-blue-500/30 bg-blue-500/20 px-3 py-1 text-xs font-semibold text-blue-200">{tool}</span>)}
  </div>
</article>
