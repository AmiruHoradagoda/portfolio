---
interface Props {
  id: string;
  eyebrow?: string;
  title: string;
  intro?: string;
}

const { id, eyebrow, title, intro } = Astro.props;
---

<section id={id} class="scroll-mt-24 py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-5 sm:px-6 lg:px-8">
    <div class="mx-auto mb-10 max-w-3xl text-center">
      {eyebrow && <p class="mb-3 text-sm font-semibold uppercase tracking-[0.16em] text-blue-300">{eyebrow}</p>}
      <h2 class="text-4xl font-bold text-white sm:text-5xl">{title}</h2>
      {intro && <p class="mt-4 text-base leading-7 text-slate-400">{intro}</p>}
    </div>
    <slot />
  </div>
</section>
