---
import { skillTabs } from "../data/profile";
import { getTechLogo } from "../utils/techLogos";
---

<div class="w-full" data-skill-tabs>
  <div class="mb-8 flex flex-wrap justify-center gap-2 border-b border-white/10 pb-6 md:gap-4" role="tablist" aria-label="Skill categories">
    {skillTabs.map((tab, index) => (
      <button
        class:list={[
          "relative min-h-10 flex-none rounded-lg px-4 py-2 text-sm font-semibold transition duration-300",
          index === 0 ? "bg-white/10 text-blue-300 ring-1 ring-blue-400/40" : "text-slate-400 hover:bg-white/10 hover:text-white",
        ]}
        type="button"
        role="tab"
        aria-selected={index === 0 ? "true" : "false"}
        aria-controls={`skill-panel-${tab.id}`}
        id={`skill-tab-${tab.id}`}
        data-skill-tab={tab.id}
      >
        {tab.label}
      </button>
    ))}
  </div>

  <div>
    {skillTabs.map((tab, index) => (
      <section
        id={`skill-panel-${tab.id}`}
        role="tabpanel"
        aria-labelledby={`skill-tab-${tab.id}`}
        class:list={[index === 0 ? "block" : "hidden"]}
        data-skill-panel={tab.id}
      >
        <p class="mx-auto max-w-3xl text-center text-sm leading-6 text-slate-400">{tab.description}</p>
        <div class="mt-8 grid grid-cols-3 gap-x-5 gap-y-8 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 xl:grid-cols-8">
          {tab.items.map((item) => {
            const logo = getTechLogo(item);
            return (
              <div class="group flex min-h-28 flex-col items-center justify-start text-center">
                <div class="flex h-16 w-16 items-center justify-center rounded-xl bg-white shadow-sm ring-1 ring-white/10 transition duration-300 group-hover:-translate-y-1 group-hover:shadow-blue-500/20">
                  <img
                    src={logo}
                    alt={`${item} logo`}
                    class="h-11 w-11 object-contain"
                    loading="lazy"
                  />
                </div>
                <p class="mt-3 max-w-24 text-sm font-semibold leading-5 text-white">{item}</p>
              </div>
            );
          })}
        </div>
      </section>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll("[data-skill-tabs]").forEach((root) => {
    const tabs = Array.from(root.querySelectorAll("[data-skill-tab]"));
    const panels = Array.from(root.querySelectorAll("[data-skill-panel]"));

    function selectTab(id) {
      tabs.forEach((tab) => {
        const isSelected = tab.getAttribute("data-skill-tab") === id;
        tab.setAttribute("aria-selected", String(isSelected));
        tab.classList.toggle("bg-white/10", isSelected);
        tab.classList.toggle("text-blue-300", isSelected);
        tab.classList.toggle("ring-1", isSelected);
        tab.classList.toggle("ring-blue-400/40", isSelected);
        tab.classList.toggle("text-slate-400", !isSelected);
      });

      panels.forEach((panel) => {
        panel.classList.toggle("hidden", panel.getAttribute("data-skill-panel") !== id);
        panel.classList.toggle("block", panel.getAttribute("data-skill-panel") === id);
      });
    }

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => selectTab(tab.getAttribute("data-skill-tab")));
    });
  });
</script>
