---
import { Download, Mail, MapPin, Phone, Send } from "@lucide/astro";
import { profile } from "../data/profile";
import { assetPath } from "../utils/paths";

const cvUrl = assetPath(profile.cvPath);
const contactItems = [
  {
    label: "Email",
    value: profile.email,
    href: `mailto:${profile.email}`,
    Icon: Mail,
  },
  {
    label: "Phone",
    value: profile.phone,
    href: `tel:${profile.phone.replace(/\s/g, "")}`,
    Icon: Phone,
  },
  {
    label: "Location",
    value: profile.location,
    href: undefined,
    Icon: MapPin,
  },
];
---

<section id="contact" class="scroll-mt-24 border-t border-white/10 bg-blue-600/5 py-16 text-white sm:py-20">
  <div class="mx-auto grid max-w-6xl gap-10 px-5 sm:px-6 lg:grid-cols-[0.9fr_1.5fr] lg:px-8">
    <aside>
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-blue-300">Contact</p>
      <h2 class="mt-3 text-4xl font-bold sm:text-5xl">Build something useful.</h2>
      <p class="mt-4 text-base leading-7 text-slate-400">
        Send a message for internships, collaborations, full-stack work, DevOps automation, or AI-focused projects.
      </p>

      <div class="mt-7 grid gap-5">
        {
          contactItems.map(({ label, value, href, Icon }) => (
            <div class="flex gap-4">
              <Icon class="mt-1 h-5 w-5 flex-none text-blue-300" aria-hidden="true" stroke-width={2} />
              <div>
                <h3 class="text-sm font-semibold text-white">{label}</h3>
                {
                  href ? (
                    <a class="mt-1 block text-sm text-slate-400 transition hover:text-blue-300" href={href}>
                      {value}
                    </a>
                  ) : (
                    <p class="mt-1 text-sm text-slate-400">{value}</p>
                  )
                }
              </div>
            </div>
          ))
        }
      </div>

      <a
        class="mt-8 inline-flex min-h-12 items-center justify-center gap-2 rounded-xl border border-white/20 bg-white/10 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/20"
        href={cvUrl}
        download
      >
        <Download class="h-4 w-4" aria-hidden="true" stroke-width={2} />
        Download Resume (PDF)
      </a>
    </aside>

    <form class="glass-card grid gap-4 rounded-2xl p-5 sm:p-6" action={`mailto:${profile.email}`} method="post" enctype="text/plain">
      <div class="grid gap-4 md:grid-cols-2">
        <label class="grid gap-2 text-sm font-semibold">
          Name
          <input
            class="min-h-12 rounded-xl border border-white/20 bg-white/10 px-4 text-base font-normal text-white outline-none transition placeholder:text-slate-500 focus:border-blue-400/60 focus:ring-4 focus:ring-blue-500/20"
            type="text"
            name="name"
            placeholder="Your name"
            autocomplete="name"
          />
        </label>
        <label class="grid gap-2 text-sm font-semibold">
          Email
          <input
            class="min-h-12 rounded-xl border border-white/20 bg-white/10 px-4 text-base font-normal text-white outline-none transition placeholder:text-slate-500 focus:border-blue-400/60 focus:ring-4 focus:ring-blue-500/20"
            type="email"
            name="email"
            placeholder="Your email"
            autocomplete="email"
          />
        </label>
      </div>

      <label class="grid gap-2 text-sm font-semibold">
        Subject
        <input
          class="min-h-12 rounded-xl border border-white/20 bg-white/10 px-4 text-base font-normal text-white outline-none transition placeholder:text-slate-500 focus:border-blue-400/60 focus:ring-4 focus:ring-blue-500/20"
          type="text"
          name="subject"
          placeholder="Project, internship, or collaboration"
        />
      </label>

      <label class="grid gap-2 text-sm font-semibold">
        Message
        <textarea
          class="min-h-36 resize-y rounded-xl border border-white/20 bg-white/10 px-4 py-3 text-base font-normal text-white outline-none transition placeholder:text-slate-500 focus:border-blue-400/60 focus:ring-4 focus:ring-blue-500/20"
          name="message"
          placeholder="Tell me what you want to build"
        ></textarea>
      </label>

      <div class="flex justify-start md:justify-end">
        <button
          class="inline-flex min-h-12 items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-blue-600 to-violet-600 px-5 py-3 text-base font-semibold text-white transition hover:from-blue-700 hover:to-violet-700 focus:outline-none focus:ring-4 focus:ring-blue-500/20"
          type="submit"
        >
          <Send class="h-5 w-5" aria-hidden="true" stroke-width={2} />
          Send Message
        </button>
      </div>
    </form>
  </div>
</section>
