---
import { Download, Mail, MapPin, Phone, Send } from "@lucide/astro";
import { profile } from "../data/profile";
import { assetPath } from "../utils/paths";

const cvUrl = assetPath(profile.cvPath);
const web3FormsAccessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? "";
const contactItems = [
  {
    label: "Email",
    value: profile.email,
    href: `mailto:${profile.email}`,
    Icon: Mail,
  },
  {
    label: "Phone",
    value: profile.phone,
    href: `tel:${profile.phone.replace(/\s/g, "")}`,
    Icon: Phone,
  },
  {
    label: "Location",
    value: profile.location,
    href: undefined,
    Icon: MapPin,
  },
];
---

<section id="contact" class="scroll-mt-24 border-t border-white/10 bg-blue-600/5 py-16 text-white sm:py-20">
  <div class="mx-auto grid max-w-6xl gap-10 px-5 sm:px-6 lg:grid-cols-[0.9fr_1.5fr] lg:px-8">
    <aside>
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-blue-300">Contact</p>
      <h2 class="mt-3 text-4xl font-bold sm:text-5xl">Build something useful.</h2>
      <p class="mt-4 text-base leading-7 text-slate-400">
        Send a message for internships, collaborations, full-stack work, DevOps automation, or AI-focused projects.
      </p>

      <div class="mt-7 grid gap-5">
        {
          contactItems.map(({ label, value, href, Icon }) => (
            <div class="flex gap-4">
              <Icon class="mt-1 h-5 w-5 flex-none text-blue-300" aria-hidden="true" stroke-width={2} />
              <div>
                <h3 class="text-sm font-semibold text-white">{label}</h3>
                {
                  href ? (
                    <a class="mt-1 block text-sm text-slate-400 transition hover:text-blue-300" href={href}>
                      {value}
                    </a>
                  ) : (
                    <p class="mt-1 text-sm text-slate-400">{value}</p>
                  )
                }
              </div>
            </div>
          ))
        }
      </div>

      <a
        class="mt-8 inline-flex min-h-12 items-center justify-center gap-2 rounded-xl border border-white/20 bg-white/10 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/20"
        href={cvUrl}
        download
      >
        <Download class="h-4 w-4" aria-hidden="true" stroke-width={2} />
        Download Resume (PDF)
      </a>
    </aside>

    <form
      class="glass-card grid gap-4 rounded-2xl p-5 sm:p-6"
      action="https://api.web3forms.com/submit"
      method="post"
      data-contact-form
    >
      <input type="hidden" name="access_key" value={web3FormsAccessKey} />
      <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />
      <input type="hidden" name="redirect" value={assetPath("#contact")} />

      <div class="grid gap-4 md:grid-cols-2">
        <label class="grid gap-2 text-sm font-semibold">
          Name
          <input
            class="min-h-12 rounded-xl border border-white/20 bg-white/10 px-4 text-base font-normal text-white outline-none transition placeholder:text-slate-500 focus:border-blue-400/60 focus:ring-4 focus:ring-blue-500/20"
            type="text"
            name="name"
            placeholder="Your name"
            autocomplete="name"
            required
          />
        </label>
        <label class="grid gap-2 text-sm font-semibold">
          Email
          <input
            class="min-h-12 rounded-xl border border-white/20 bg-white/10 px-4 text-base font-normal text-white outline-none transition placeholder:text-slate-500 focus:border-blue-400/60 focus:ring-4 focus:ring-blue-500/20"
            type="email"
            name="email"
            placeholder="Your email"
            autocomplete="email"
            required
          />
        </label>
      </div>

      <label class="grid gap-2 text-sm font-semibold">
        Subject
        <input
          class="min-h-12 rounded-xl border border-white/20 bg-white/10 px-4 text-base font-normal text-white outline-none transition placeholder:text-slate-500 focus:border-blue-400/60 focus:ring-4 focus:ring-blue-500/20"
          type="text"
          name="subject"
          placeholder="Project, internship, or collaboration"
          required
        />
      </label>

      <label class="grid gap-2 text-sm font-semibold">
        Message
        <textarea
          class="min-h-36 resize-y rounded-xl border border-white/20 bg-white/10 px-4 py-3 text-base font-normal text-white outline-none transition placeholder:text-slate-500 focus:border-blue-400/60 focus:ring-4 focus:ring-blue-500/20"
          name="message"
          placeholder="Tell me what you want to build"
          required
        ></textarea>
      </label>

      <p class="hidden rounded-xl border px-4 py-3 text-sm font-semibold" data-contact-status></p>

      <div class="flex justify-start md:justify-end">
        <button
          class="inline-flex min-h-12 items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-blue-600 to-violet-600 px-5 py-3 text-base font-semibold text-white transition hover:from-blue-700 hover:to-violet-700 focus:outline-none focus:ring-4 focus:ring-blue-500/20"
          type="submit"
          data-contact-submit
        >
          <Send class="h-5 w-5" aria-hidden="true" stroke-width={2} />
          Send Message
        </button>
      </div>
    </form>
  </div>
</section>

<script>
  const contactForm = document.querySelector("[data-contact-form]");
  const contactStatus = document.querySelector("[data-contact-status]");
  const contactSubmit = document.querySelector("[data-contact-submit]");
  let contactStatusTimeout;

  function setContactStatus(message, type) {
    if (!(contactStatus instanceof HTMLElement)) {
      return;
    }

    window.clearTimeout(contactStatusTimeout);
    contactStatus.textContent = message;
    contactStatus.classList.remove(
      "hidden",
      "border-blue-400/30",
      "bg-blue-500/10",
      "text-blue-100",
      "border-emerald-400/30",
      "bg-emerald-500/10",
      "text-emerald-100",
      "border-red-400/30",
      "bg-red-500/10",
      "text-red-100",
    );

    const statusClasses =
      type === "success"
        ? ["border-emerald-400/30", "bg-emerald-500/10", "text-emerald-100"]
        : type === "error"
          ? ["border-red-400/30", "bg-red-500/10", "text-red-100"]
          : ["border-blue-400/30", "bg-blue-500/10", "text-blue-100"];

    contactStatus.classList.add(...statusClasses);

    if (type === "success") {
      contactStatusTimeout = window.setTimeout(() => {
        contactStatus.classList.add("hidden");
        contactStatus.textContent = "";
      }, 5000);
    }
  }

  if (contactForm instanceof HTMLFormElement) {
    contactForm.addEventListener("submit", async (event) => {
      event.preventDefault();

      const formData = new FormData(contactForm);
      const accessKey = String(formData.get("access_key") ?? "");

      if (!accessKey) {
        setContactStatus("Contact form is not configured yet. Please email me directly.", "error");
        return;
      }

      if (contactSubmit instanceof HTMLButtonElement) {
        contactSubmit.disabled = true;
        contactSubmit.classList.add("cursor-not-allowed", "opacity-70");
      }

      setContactStatus("Sending message...", "loading");

      try {
        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: {
            Accept: "application/json",
            "Content-Type": "application/json",
          },
          body: JSON.stringify(Object.fromEntries(formData)),
        });

        const result = await response.json();

        if (response.ok && result.success) {
          contactForm.reset();
          setContactStatus("Message sent. I will get back to you soon.", "success");
          return;
        }

        setContactStatus(result.message || "Message could not be sent. Please try again.", "error");
      } catch {
        setContactStatus("Message could not be sent. Please check your connection and try again.", "error");
      } finally {
        if (contactSubmit instanceof HTMLButtonElement) {
          contactSubmit.disabled = false;
          contactSubmit.classList.remove("cursor-not-allowed", "opacity-70");
        }
      }
    });
  }
</script>
