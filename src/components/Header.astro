---
import { Menu, X } from "@lucide/astro";
import { profile } from "../data/profile";
import { assetPath } from "../utils/paths";

const navItems = [
  { label: "Home", href: assetPath("") },
  { label: "Projects", href: assetPath("projects/") },
  { label: "Journey", href: assetPath("journey/") },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-[#0a0e27]/85 backdrop-blur-md">
  <nav class="mx-auto flex min-h-16 max-w-6xl items-center justify-between px-5 sm:px-6 lg:px-8" aria-label="Primary navigation">
    <a href={assetPath("")} class="text-xl font-bold text-white">{profile.name}</a>

    <div class="ml-auto hidden items-center gap-6 md:flex">
      {navItems.map((item) => (
        <a class="text-sm font-medium text-slate-400 transition hover:text-white" href={item.href}>{item.label}</a>
      ))}
    </div>

    <button
      class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-white/20 bg-white/10 text-white md:hidden"
      type="button"
      aria-label="Open navigation menu"
      aria-expanded="false"
      data-menu-toggle
    >
      <Menu class="h-5 w-5 data-[state=open]:hidden" aria-hidden="true" stroke-width={2} data-menu-open-icon />
      <X class="hidden h-5 w-5" aria-hidden="true" stroke-width={2} data-menu-close-icon />
    </button>
  </nav>

  <div class="hidden border-t border-white/10 bg-[#0a0e27] md:hidden" data-mobile-menu>
    <div class="mx-auto grid max-w-6xl gap-1 px-5 py-4">
      {navItems.map((item) => (
        <a class="rounded-lg px-3 py-3 text-sm font-semibold text-slate-400 transition hover:bg-white/10 hover:text-white" href={item.href} data-mobile-link>
          {item.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const menu = document.querySelector("[data-mobile-menu]");
  const button = document.querySelector("[data-menu-toggle]");
  const openIcon = document.querySelector("[data-menu-open-icon]");
  const closeIcon = document.querySelector("[data-menu-close-icon]");

  if (menu instanceof HTMLElement && button instanceof HTMLButtonElement && openIcon instanceof SVGElement && closeIcon instanceof SVGElement) {
    function setOpen(isOpen) {
      menu.classList.toggle("hidden", !isOpen);
      button.setAttribute("aria-expanded", String(isOpen));
      openIcon.classList.toggle("hidden", isOpen);
      closeIcon.classList.toggle("hidden", !isOpen);
    }

    button.addEventListener("click", () => setOpen(menu.classList.contains("hidden")));
    menu.querySelectorAll("[data-mobile-link]").forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });
  }
</script>
